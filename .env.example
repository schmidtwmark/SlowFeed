# Required
# Use localhost for local development, db for Docker Compose
DATABASE_URL=postgresql://slowfeed:slowfeed@localhost:5432/slowfeed
ENCRYPTION_KEY=generate-a-random-32-char-string-here

# Optional overrides
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Base URL (used for feed links)
# Use localhost for local development, or your Cloudflare Tunnel URL for production
BASE_URL=http://localhost:3000

# WebAuthn (Passkey) Configuration
# These should match your deployment domain
WEBAUTHN_RP_ID=localhost                    # Domain for passkey binding (e.g., slowfeed.example.com)
WEBAUTHN_RP_NAME=Slowfeed                   # Display name shown to users
WEBAUTHN_ORIGIN=http://localhost:3000       # Full origin URL (must match browser)

# Skip initial poll on startup (useful for development)
# SKIP_INITIAL_POLL=true

# Required
# Use localhost for local development, db for Docker Compose
DATABASE_URL=postgresql://slowfeed:slowfeed@localhost:5432/slowfeed
ENCRYPTION_KEY=generate-a-random-32-char-string-here

# Optional overrides
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Base URL (used for feed links)
# Use localhost for local development, or your Cloudflare Tunnel URL for production
BASE_URL=http://localhost:3000

# Skip initial poll on startup (useful for development)
# SKIP_INITIAL_POLL=true

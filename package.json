{
  "name": "slowfeed",
  "version": "1.0.0",
  "description": "Self-hosted RSS feed aggregator for Reddit, Bluesky, and YouTube",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["rss", "feed", "aggregator", "reddit", "bluesky", "youtube"],
  "license": "MIT",
  "dependencies": {
    "@atproto/api": "^0.13.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "feed": "^4.2.2",
    "googleapis": "^140.0.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "snoowrap": "^1.23.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.4",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
